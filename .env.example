# ============================================================
#  FootPass environment  —  copy to .env and fill in.
#  NEVER commit .env.  No secrets belong in docker-compose.yml.
# ============================================================

# --- Database (internal to the Docker network — never exposed) ---
POSTGRES_USER=footpass
POSTGRES_PASSWORD=change_me_use_a_long_random_string
POSTGRES_DB=footpass

# --- Local data storage (images live on the filesystem, not in PG) ---
# Production default is /srv/footpass (created by install-zimaboard.sh).
# For a no-sudo local test, point this at a home path, e.g.
#   FOOTPASS_DATA_DIR=/home/swarm/Desktop/footpass/data
FOOTPASS_DATA_DIR=/srv/footpass

# --- Optional NAS backup (Phase 4). Share must already be mounted by Linux. ---
FOOTPASS_BACKUP_DIR=/mnt/nas/Foot-Passport

# --- Application ---
FOOTPASS_ENV=production
FOOTPASS_VERSION=0.1.0
FOOTPASS_HOSTNAME=footpass.local
FOOTPASS_TZ=America/New_York

# --- Security ---
# Generate with:  openssl rand -hex 32
FOOTPASS_SECRET_KEY=change_me_generate_a_random_32_byte_hex_string
